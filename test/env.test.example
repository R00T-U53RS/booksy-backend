# Copy this file to the project root as `.env.test` and adjust values.
# Integration tests load `.env.test` first; if it is missing, `jest.setup.ts` falls back to `.env`.
#
# The database named in DB_DATABASE must exist in Postgres. With Docker from `db/`, create it once:
#   docker exec -it postgres psql -U postgres -c "CREATE DATABASE booksy_test;"
# See db/README.md for details (including fresh volumes + `db/init/`).
#
# NODE_ENV must be one of: local | staging | production (see src/config/env.validation.ts).
# Use `local` for integration tests.

NODE_ENV=local
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=booksy_test
DB_SYNC=true

JWT_SECRET=test-jwt-secret-minimum-length-for-validation
JWT_EXPIRES_IN=7d
